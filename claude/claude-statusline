#!/usr/bin/env bash
# Self-sufficient Claude Code statusline. Replaces the former Starship bridge.

input=$(cat)

RESET=$'\033[0m'
BOLD_BLUE=$'\033[1;34m'
BOLD_CYAN=$'\033[1;36m'
BOLD_PURPLE=$'\033[1;35m'
DIM_WHITE=$'\033[2;37m'
YELLOW=$'\033[33m'
BOLD_YELLOW=$'\033[1;33m'
BOLD_ORANGE=$'\033[1;38;2;255;136;0m'
BOLD_RED=$'\033[1;31m'
BOLD_GREEN=$'\033[1;32m'

jq_get() {
  printf '%s' "$input" | jq -r "$1" 2>/dev/null
}

segment() {
  printf '%b%s%b' "$1" "$2" "$RESET"
}

map_model() {
  case "$1" in
    calude-fable-5*) printf 'Fable 5' ;;
    Claude-Opus-4.8*) printf 'Opus 4.8' ;;
    opus) printf 'Opus 4.8' ;;
    sonnet) printf 'Sonnet 4.6' ;;
    haiku) printf 'Haiku 4.5' ;;
    claude-opus-4-8*) printf 'Opus 4.8' ;;
    claude-opus-4-7*) printf 'Opus 4.7' ;;
    claude-sonnet-4-6*) printf 'Sonnet 4.6' ;;
    claude-haiku-4-5*) printf 'Haiku 4.5' ;;
    '') printf 'Unknown' ;;
    *) printf '%s' "$1" ;;
  esac
}

repeat_char() {
  local char=$1
  local count=$2
  local out=""

  while [ "$count" -gt 0 ]; do
    out+="$char"
    count=$((count - 1))
  done

  printf '%s' "$out"
}

context_gauge() {
  local counts full partial empty
  counts=$(awk -v pct="$1" '
    BEGIN {
      if (pct < 0) pct = 0
      if (pct > 100) pct = 100
      scaled = pct * 10 / 100
      full = int(scaled)
      partial = (full < 10 && scaled > full) ? 1 : 0
      empty = 10 - full - partial
      printf "%d %d %d", full, partial, empty
    }
  ')
  read -r full partial empty <<<"$counts"

  repeat_char "█" "$full"
  repeat_char "▒" "$partial"
  repeat_char "░" "$empty"
}

humanize_tokens() {
  awk -v tokens="$1" '
    function scaled(value, suffix) {
      if (value == int(value)) {
        printf "%d%s", value, suffix
      } else {
        printf "%.1f%s", value, suffix
      }
    }

    BEGIN {
      if (tokens == "" || tokens == "null") {
        exit
      }

      tokens += 0
      if (tokens >= 1000000) {
        scaled(tokens / 1000000, "M")
      } else if (tokens >= 1000) {
        scaled(tokens / 1000, "k")
      } else {
        printf "%d", tokens
      }
    }
  '
}

home_relative() {
  local path=$1

  if [ -n "${HOME:-}" ] && [ "$path" = "$HOME" ]; then
    printf '~'
  elif [ -n "${HOME:-}" ] && [[ "$path" == "$HOME/"* ]]; then
    printf '~/%s' "${path#"$HOME"/}"
  else
    printf '%s' "$path"
  fi
}

number_gt_zero() {
  awk -v value="$1" 'BEGIN { exit !(value + 0 > 0) }'
}

number_ge() {
  awk -v value="$1" -v threshold="$2" 'BEGIN { exit !(value + 0 >= threshold + 0) }'
}

model_id=$(jq_get '.model.id // .model.display_name // empty')
thinking=$(jq_get '.thinking.enabled // false')
effort=$(jq_get '.effort.level // empty')
[ -z "$effort" ] && effort=${CLAUDE_CODE_EFFORT_LEVEL:-}
pct=$(jq_get '.context_window.used_percentage // empty')
context_total=$(jq_get '.context_window.context_window_size // empty')
cost=$(jq_get '.cost.total_cost_usd // empty')
cwd=$(jq_get '.workspace.current_dir // .cwd // empty')
[ -z "$cwd" ] && cwd=$PWD

output=""
output+=$(segment "$BOLD_BLUE" "🤖 $(map_model "$model_id")")

if [ "$thinking" = "true" ]; then
  output+=$(segment "$BOLD_PURPLE" "  🧠")
fi

case "$effort" in
  low) output+=$(segment "$DIM_WHITE" " ⚡low") ;;
  medium) output+=$(segment "$YELLOW" " ⚡medium") ;;
  high) output+=$(segment "$BOLD_YELLOW" "  ⚡high") ;;
  xhigh) output+=$(segment "$BOLD_ORANGE" "  ⚡xhigh") ;;
  max) output+=$(segment "$BOLD_RED" "  ⚡max") ;;
esac

if [ -n "$pct" ] && number_gt_zero "$pct"; then
  context_style=$BOLD_GREEN
  if number_ge "$pct" 80; then
    context_style=$BOLD_RED
  elif number_ge "$pct" 60; then
    context_style=$BOLD_ORANGE
  elif number_ge "$pct" 40; then
    context_style=$BOLD_YELLOW
  fi

  pct_display=$(awk -v pct="$pct" 'BEGIN { printf "%d", pct + 0 }')
  context_size=$(humanize_tokens "$context_total")
  output+=$(segment "$context_style" "    🪙   $(context_gauge "$pct") ${pct_display}% (${context_size})")
fi

if [ -n "$cost" ] && number_ge "$cost" 0.01; then
  cost_style=$BOLD_GREEN
  if number_ge "$cost" 5; then
    cost_style=$BOLD_RED
  elif number_ge "$cost" 1; then
    cost_style=$BOLD_YELLOW
  fi

  cost_display=$(awk -v cost="$cost" 'BEGIN { printf "%.2f", cost + 0 }')
  output+=$(segment "$cost_style" "    💰 \$${cost_display}")
fi

output+=$(segment "$BOLD_CYAN" "    📁 $(home_relative "$cwd")")

if git -C "$cwd" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  branch=$(git -C "$cwd" branch --show-current 2>/dev/null)
  if [ -n "$branch" ]; then
    output+=$(segment "$BOLD_PURPLE" "     ${branch}")
  fi
fi

printf '%s\n' "$output"
